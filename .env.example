# Stellar Network name (testnet)
STELLAR_NETWORK=testnet

# The active Stellar Testnet RPC endpoint
STELLAR_RPC_URL=https://soroban-testnet.stellar.org:443

# The precise testnet network passphrase string
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# Private key of the deployer account (keep this secure and do not commit the actual key)
DEPLOYER_SECRET_KEY="YOUR_SECRET_KEY_HERE"

# Deployed contract address outputted from deployment commands
DEPLOYED_CONTRACT_ID="YOUR_CONTRACT_ID_HERE"
