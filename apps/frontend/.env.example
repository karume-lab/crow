# The URL of the backend API
VITE_API_URL=http://localhost:3001/api

# The deployed Soroban Micro-Escrow contract ID
VITE_CONTRACT_ID=YOUR_CONTRACT_ID_HERE

# Soroban Network settings
VITE_NETWORK_PASSPHRASE="Standalone Network ; February 2017"
VITE_RPC_URL="http://localhost:8000/soroban/rpc"

# Simulated Profile Addresses (Populated by reset_env.sh)
VITE_MOCK_CLIENT=GB...
VITE_MOCK_FREELANCER=GD...
VITE_MOCK_ARBITER=GD...

# Default Token Contract (Native XLM on local)
VITE_DEFAULT_TOKEN=CD...
